##############################################################################
# gitlab-runner-stack — Environment Configuration
##############################################################################
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run:  ./scripts/init.sh && docker compose up -d
##############################################################################

#----------------------------------------------------------------------------
# Core — REQUIRED
#----------------------------------------------------------------------------

# GitLab server URL (with https:// or http://)
GITLAB_URL=https://gitlab.example.com

# Runner authentication token (GitLab 16.0+).
# Create a runner in GitLab UI → Settings → CI/CD → Runners → New project runner
# Copy the authentication token here.
RUNNER_AUTH_TOKEN=

# Legacy registration token (GitLab < 16.0 or if auth tokens are disabled).
# Leave RUNNER_AUTH_TOKEN empty to use this instead.
REGISTRATION_TOKEN=

#----------------------------------------------------------------------------
# Runner
#----------------------------------------------------------------------------

# Display name for the runner in GitLab
RUNNER_NAME=gitlab-runner-01

# Tags (comma-separated) — used to route jobs to this runner
RUNNER_TAGS=docker,linux

# Number of concurrent jobs this runner can handle
RUNNER_CONCURRENT=4

# Maximum number of jobs the runner will accept (0 = unlimited)
RUNNER_LIMIT=0

# Maximum time (seconds) a single job can run before being killed (0 = unlimited)
RUNNER_TIMEOUT=3600

# Default Docker image for CI jobs (jobs can override with image:)
RUNNER_DEFAULT_IMAGE=alpine:latest

# Run CI job containers in privileged mode (needed for Docker-in-Docker builds)
RUNNER_PRIVILEGED=true

#----------------------------------------------------------------------------
# Docker Daemon (DinD)
#----------------------------------------------------------------------------

# Docker Engine image (DinD)
DOCKER_DIND_IMAGE=docker:29-dind

# GitLab Runner image
GITLAB_RUNNER_IMAGE=gitlab/gitlab-runner:latest

# Docker storage driver (overlay2 recommended; vfs for limited environments)
DOCKER_DRIVER=overlay2

# Insecure registries (optional, comma-separated)
# DOCKER_INSECURE_REGISTRIES=registry.local:5000

# Registry mirrors (optional, comma-separated)
# DOCKER_REGISTRY_MIRRORS=https://mirror.gcr.io

#----------------------------------------------------------------------------
# Resource Limits
#----------------------------------------------------------------------------

# Memory limit for the Docker daemon (e.g. 4g, 512m)
DOCKER_MEMORY=

# CPU limit for the Docker daemon (e.g. 2.0, 0.5)
DOCKER_CPUS=

#----------------------------------------------------------------------------
# TLS Certificates
#----------------------------------------------------------------------------

# Certificates are valid for this many days
CERT_VALIDITY_DAYS=3650

# Server hostname/IP for the TLS certificate (the dockerd service name)
DOCKER_TLS_HOST=docker

# Certificate key size (bits)
CERT_KEY_SIZE=4096

#----------------------------------------------------------------------------
# Network
#----------------------------------------------------------------------------

# Docker Compose project name (affects container & network naming)
COMPOSE_PROJECT_NAME=gitlab-runner-stack

#----------------------------------------------------------------------------
# Log Rotation
#----------------------------------------------------------------------------

# Max log file size before rotation
LOG_MAX_SIZE=50m

# Number of rotated log files to keep
LOG_MAX_FILE=5

#----------------------------------------------------------------------------
# Cache (Phase 2 placeholder — leave as-is for now)
#----------------------------------------------------------------------------

# Cache directory inside the container
CACHE_DIR=/cache

#----------------------------------------------------------------------------
# Timezone
#----------------------------------------------------------------------------

TZ=UTC
