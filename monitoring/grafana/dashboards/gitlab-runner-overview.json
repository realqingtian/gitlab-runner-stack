{
  "annotations": { "list": [] },
  "title": "GitLab Runner Overview",
  "uid": "gitlab-runner-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["gitlab", "runner"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Runner Status",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"gitlab-runner\"}", "legendFormat": "status" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Jobs",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(gitlab_runner_jobs_total)", "legendFormat": "total" }
      ]
    },
    {
      "type": "stat",
      "title": "Failed Jobs",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(gitlab_runner_jobs_total{status=\"failed\"})", "legendFormat": "failed" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 1 }] }
        }
      }
    },
    {
      "type": "graph",
      "title": "Jobs Over Time (by status)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        { "expr": "rate(gitlab_runner_jobs_total[5m])", "legendFormat": "{{status}}" }
      ]
    },
    {
      "type": "graph",
      "title": "Job Duration (seconds)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(gitlab_runner_job_duration_seconds_bucket[5m]))", "legendFormat": "p95" }
      ]
    }
  ]
}
